---
import BaseLayout from '../../components/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const tel = '02651-4019589';
const telHref = 'tel:+4926514019589';
---

<BaseLayout
  title="Heizung & Wärmepumpe Mayen | Paul Martini Sanitär"
  description="Heizungsmodernisierung & Wärmepumpen-Installation in Mayen — Viessmann, Vaillant, Bosch. Förderung BAFA/KfW. ☎ 02651-4019589"
  canonical="/leistungen/heizung/"
>
  <Header />

  <main class="pt-16 sm:pt-20">
    <section class="bg-[var(--color-secondary)] py-16 sm:py-24 text-center text-white" aria-labelledby="page-heading">
      <div class="max-w-3xl mx-auto px-4">
        <span class="inline-block bg-white/10 text-white/80 text-sm px-4 py-1.5 rounded-full mb-4">Heizung & Energie</span>
        <h1 id="page-heading" class="text-white mb-4">Heizung & Wärmepumpe<br /><span class="text-[var(--color-accent-light)]">Mayen & Umgebung</span></h1>
        <p class="text-white/75 text-lg max-w-2xl mx-auto">
          Moderne Heizsysteme, Wärmepumpen und Smart-Home-Integration. Wir helfen Ihnen beim Umstieg
          auf erneuerbare Energien — mit BAFA- und KfW-Förderung.
        </p>
      </div>
    </section>

    <section class="py-16 sm:py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="grid sm:grid-cols-2 gap-8 mb-12">
          {[
            { titel: 'Wärmepumpe', text: 'Luft-Wasser-Wärmepumpen und Sole-Wasser-Systeme. Bis zu 70% weniger Heizkosten.' },
            { titel: 'Gasheizung & Hybridheizung', text: 'Moderne Brennwertkessel und Hybridlösungen für optimale Effizienz.' },
            { titel: 'Heizungsmodernisierung', text: 'Alte Heizanlage raus, moderne Technik rein — wir kümmern uns um die komplette Umrüstung.' },
            { titel: 'BAFA & KfW Förderung', text: 'Wir kennen alle Förderprogramme und helfen Ihnen, das Maximum herauszuholen.' },
          ].map(l => (
            <div class="bg-[var(--color-surface)] rounded-xl p-6">
              <h3 class="font-heading font-700 text-[var(--color-text)] mb-2">{l.titel}</h3>
              <p class="text-[var(--color-text-muted)] text-sm">{l.text}</p>
            </div>
          ))}
        </div>

        <div class="bg-[var(--color-primary)] rounded-2xl p-8 text-center text-white">
          <h2 class="text-white text-2xl font-heading font-800 mb-3">Heizungsberatung vereinbaren</h2>
          <p class="text-white/80 mb-6">Kostenloser Vorort-Termin — wir prüfen Ihr Haus und empfehlen die beste Lösung.</p>
          <a href={telHref} class="inline-flex items-center gap-2 bg-white text-[var(--color-primary-text)] font-bold px-6 py-3 rounded-xl hover:bg-yellow-50 transition-colors">
            {tel} anrufen
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
