---
import BaseLayout from '../../components/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const tel = '02651-4019589';
const telHref = 'tel:+4926514019589';
const email = 'info@paul-martini.de';
---

<BaseLayout
  title="Heizung & Wärmepumpe Mayen | Paul Martini Sanitär"
  description="Heizungsmodernisierung & Wärmepumpen-Installation in Mayen — Viessmann, Vaillant, Bosch. Förderung BAFA/KfW. ☎ 02651-4019589"
  canonical="/leistungen/heizung/"
>
  <Header />

  <main class="pt-16 sm:pt-20">

    <!-- Hero -->
    <section class="relative bg-[var(--color-secondary)] py-20 sm:py-28 overflow-hidden" aria-labelledby="page-heading">
      <div class="absolute inset-0">
        <img
          src="/images/heizung-hero.jpg"
          alt="Moderne Heizungsanlage und Wärmepumpe"
          class="w-full h-full object-cover opacity-25"
          width="1200"
          height="782"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-secondary)] via-[var(--color-secondary)]/80 to-transparent"></div>
      </div>
      <div class="relative max-w-5xl mx-auto px-4 sm:px-6">
        <div class="max-w-2xl">
          <span class="inline-block bg-[var(--color-accent)] text-white text-sm font-semibold px-4 py-1.5 rounded-full mb-6">Heizung & Energie</span>
          <h1 id="page-heading" class="text-white mb-5">
            Heizung & Wärmepumpe<br />
            <span class="text-[var(--color-accent-light)]">Mayen & Umgebung</span>
          </h1>
          <p class="text-white/75 text-lg leading-relaxed mb-8">
            Moderne Heizsysteme, Wärmepumpen und Smart-Home-Integration. Wir helfen Ihnen beim Umstieg
            auf erneuerbare Energien — mit BAFA- und KfW-Förderung bis zu 70%.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href={telHref} class="inline-flex items-center justify-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold px-7 py-4 rounded-xl transition-colors text-lg">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
              </svg>
              Jetzt anrufen
            </a>
            <a href="/kontakt/" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-7 py-4 rounded-xl transition-colors text-lg border border-white/20">
              Angebot anfragen
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Bar -->
    <section class="bg-[var(--color-primary)] py-4" aria-label="Vertrauenssignale">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="flex flex-wrap justify-center gap-6 sm:gap-10 text-white text-sm font-semibold text-center">
          <span>✓ BAFA & KfW Förderung</span>
          <span>✓ Viessmann & Vaillant Partner</span>
          <span>✓ Meisterbetrieb</span>
          <span>✓ Kostenlose Beratung</span>
        </div>
      </div>
    </section>

    <!-- Leistungen -->
    <section class="py-20 sm:py-24 bg-white" aria-labelledby="leistungen-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-14 fade-up">
          <span class="inline-block bg-[var(--color-primary)]/10 text-[var(--color-primary-text)] font-semibold text-sm px-4 py-1.5 rounded-full mb-4">Unsere Heizungsleistungen</span>
          <h2 id="leistungen-heading" class="mb-3">Was wir für Sie tun</h2>
          <p class="text-[var(--color-text-muted)] max-w-xl mx-auto">
            Von der Wärmepumpe bis zur Hybridheizung — wir planen, installieren und warten Ihre Heizanlage.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 gap-6">
          {[
            {
              titel: 'Wärmepumpe installieren',
              text: 'Luft-Wasser-Wärmepumpen und Sole-Wasser-Systeme für Ihr Haus. Bis zu 70% weniger Heizkosten im Vergleich zu alten Öl- und Gasheizungen. Wir übernehmen Planung, Installation und Inbetriebnahme.',
            },
            {
              titel: 'Gasheizung & Hybridheizung',
              text: 'Moderne Brennwertkessel mit höchster Effizienz. Hybrid-Systeme kombinieren Gas mit Wärmepumpe — ideal für ältere Gebäude, die noch nicht vollständig wärmegedämmt sind.',
            },
            {
              titel: 'Heizungsmodernisierung',
              text: 'Alte Heizanlage raus, moderne Technik rein. Wir kümmern uns um die komplette Umrüstung — Demontage, Installation, Anschluss, Einregulierung und Übergabe.',
            },
            {
              titel: 'Fußbodenheizung',
              text: 'Flächenheizung für gleichmäßige Wärme und niedrigere Vorlauftemperaturen. Ideal in Kombination mit Wärmepumpen. Nachrüstung im Bestand und Neubau.',
            },
            {
              titel: 'Smart-Home-Heizung',
              text: 'Intelligente Thermostate, App-Steuerung und Zeitprogramme für maximalen Komfort und optimale Energieeffizienz. Kompatibel mit den führenden Systemen.',
            },
            {
              titel: 'BAFA & KfW Förderung',
              text: 'Wir kennen alle aktuellen Förderprogramme. Als eingetragenes Unternehmen können wir Ihre Förderanträge unterstützen und helfen, das Maximum herauszuholen.',
            },
          ].map((l, i) => (
            <div class="bg-[var(--color-surface)] rounded-xl p-7 fade-up" style={`transition-delay: ${i * 60}ms`}>
              <h3 class="font-heading font-700 text-[var(--color-text)] text-lg mb-3">{l.titel}</h3>
              <p class="text-[var(--color-text-muted)] leading-relaxed">{l.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Vorteile -->
    <section class="py-20 sm:py-24 bg-[var(--color-surface)]" aria-labelledby="vorteile-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="fade-up">
            <span class="inline-block bg-[var(--color-accent)]/10 text-[var(--color-accent)] font-semibold text-sm px-4 py-1.5 rounded-full mb-5">Warum jetzt modernisieren?</span>
            <h2 id="vorteile-heading" class="mb-6">Ihre Vorteile auf einen Blick</h2>
            <ul class="space-y-4">
              {[
                'Energiekosten drastisch senken — bis zu 70% Ersparnis möglich',
                'Staatliche Förderung bis zu 70% der Investitionskosten',
                'Unabhängigkeit von fossilen Brennstoffen',
                'Höherer Immobilienwert durch bessere Energieklasse',
                'Komfortablere, gleichmäßigere Wärme im ganzen Haus',
                'Umweltfreundlich heizen mit erneuerbaren Energien',
              ].map(v => (
                <li class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" class="text-[var(--color-accent)] shrink-0 mt-0.5" aria-hidden="true">
                    <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-[var(--color-text)]">{v}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm fade-up">
            <h3 class="font-heading font-800 text-[var(--color-text)] text-xl mb-4">Kostenlose Heizungsberatung</h3>
            <p class="text-[var(--color-text-muted)] mb-6 leading-relaxed">
              Wir kommen zu Ihnen und prüfen, welche Heizlösung am besten zu Ihrem Haus passt.
              Unverbindlich, kostenlos, vor Ort.
            </p>
            <div class="space-y-3">
              <a href={telHref} class="flex items-center gap-3 bg-[var(--color-primary)] hover:bg-[var(--color-secondary)] text-white font-bold px-6 py-4 rounded-xl transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
                </svg>
                {tel} anrufen
              </a>
              <a href={`mailto:${email}?subject=Heizungsberatung%20anfragen`} class="flex items-center gap-3 bg-[var(--color-surface)] hover:bg-[var(--color-border)] text-[var(--color-text)] font-semibold px-6 py-4 rounded-xl transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
                E-Mail schreiben
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 sm:py-24 bg-white" aria-labelledby="faq-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12 fade-up">
          <h2 id="faq-heading" class="mb-3">Häufige Fragen zur Heizungsmodernisierung</h2>
        </div>
        <div class="space-y-4">
          {[
            {
              frage: 'Lohnt sich eine Wärmepumpe für mein Haus?',
              antwort: 'Eine Wärmepumpe lohnt sich besonders für gut gedämmte Gebäude mit Fußbodenheizung oder Niedertemperaturheizkörpern. Wir schauen uns Ihr Haus an und sagen Ihnen ehrlich, ob und welche Wärmepumpe sinnvoll ist.',
            },
            {
              frage: 'Wie hoch ist die staatliche Förderung für eine neue Heizung?',
              antwort: 'Im Rahmen der Bundesförderung für effiziente Gebäude (BEG) sind bis zu 70% Förderung möglich. Der Grundfördersatz liegt bei 30%, mit einkommensabhängigem Bonus bis zu 70%. Wir helfen Ihnen dabei, die maximale Förderung zu beantragen.',
            },
            {
              frage: 'Wie lange dauert eine Heizungsinstallation?',
              antwort: 'Die reine Installationszeit beträgt je nach Anlage 1–3 Tage. Mit Demontage der alten Heizung und eventuellen Rohrleitungsarbeiten sollten Sie 2–5 Werktage einplanen.',
            },
            {
              frage: 'Können Sie auch Heizungen anderer Hersteller warten?',
              antwort: 'Ja, wir warten und reparieren Heizungsanlagen aller gängigen Hersteller — Viessmann, Vaillant, Buderus, Bosch, Wolf und weitere. Eine herstellerspezifische Ausbildung ist bei uns Standard.',
            },
            {
              frage: 'In welcher Region sind Sie tätig?',
              antwort: 'Wir sind im Raum Mayen, Koblenz, Polch, Andernach, Bad Münstereifel und Umgebung tätig. Bei Fragen zur Entfernung einfach anrufen.',
            },
          ].map((q, i) => (
            <details class="bg-[var(--color-surface)] rounded-xl overflow-hidden fade-up group" style={`transition-delay: ${i * 60}ms`}>
              <summary class="px-7 py-5 font-heading font-700 text-[var(--color-text)] cursor-pointer flex items-center justify-between gap-4 list-none hover:text-[var(--color-primary-text)] transition-colors">
                {q.frage}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="18" height="18" class="shrink-0 text-[var(--color-text-muted)] group-open:rotate-180 transition-transform" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <div class="px-7 pb-6 text-[var(--color-text-muted)] leading-relaxed">
                {q.antwort}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-[var(--color-primary)]" aria-labelledby="cta-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 id="cta-heading" class="text-white mb-4">
          Neue Heizung anfragen
        </h2>
        <p class="text-white/80 text-lg mb-8">
          Jetzt anrufen oder Anfrage stellen — kostenlose Beratung vor Ort inklusive.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={telHref} class="inline-flex items-center justify-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold px-8 py-4 rounded-xl transition-colors text-lg">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="20" height="20" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
            </svg>
            {tel} anrufen
          </a>
          <a href="/kontakt/" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-4 rounded-xl transition-colors text-lg border border-white/20">
            Online anfragen
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
