---
import BaseLayout from '../../components/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const tel = '02651-4019589';
const telHref = 'tel:+4926514019589';
---

<BaseLayout
  title="Klimaanlage installieren Mayen | Paul Martini Sanitär"
  description="Klimaanlage kaufen & installieren lassen in Mayen — energieeffizient, leise, günstig. Daikin, Mitsubishi. ☎ 02651-4019589"
  canonical="/leistungen/klimatechnik/"
>
  <Header />

  <main class="pt-16 sm:pt-20">
    <section class="bg-[var(--color-secondary)] py-16 sm:py-24 text-center text-white" aria-labelledby="page-heading">
      <div class="max-w-3xl mx-auto px-4">
        <span class="inline-block bg-white/10 text-white/80 text-sm px-4 py-1.5 rounded-full mb-4">Klimatechnik</span>
        <h1 id="page-heading" class="text-white mb-4">Klimaanlage installieren<br /><span class="text-[var(--color-accent-light)]">in Mayen & Polch</span></h1>
        <p class="text-white/75 text-lg max-w-2xl mx-auto">
          Kühlen im Sommer, heizen im Winter — moderne Klimaanlagen der neuesten Generation.
          Energiesparend, leise und professionell installiert.
        </p>
      </div>
    </section>

    <section class="py-16 sm:py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="grid sm:grid-cols-2 gap-8 mb-12">
          {[
            { titel: 'Split-Klimaanlagen', text: 'Effiziente Innen- und Außengeräte für Wohnräume, Büros und Gewerbeobjekte.' },
            { titel: 'Multi-Split-Systeme', text: 'Ein Außengerät, mehrere Innenräume — ideal für größere Objekte.' },
            { titel: 'Installation & Wartung', text: 'Fachgerechter Einbau nach Herstellervorgaben. Regelmäßige Wartungsverträge auf Wunsch.' },
            { titel: 'Beratung & Planung', text: 'Wir berechnen die richtige Leistung für Ihr Objekt und empfehlen das beste System.' },
          ].map(l => (
            <div class="bg-[var(--color-surface)] rounded-xl p-6">
              <h3 class="font-heading font-700 text-[var(--color-text)] mb-2">{l.titel}</h3>
              <p class="text-[var(--color-text-muted)] text-sm">{l.text}</p>
            </div>
          ))}
        </div>

        <div class="bg-[var(--color-primary)] rounded-2xl p-8 text-center text-white">
          <h2 class="text-white text-2xl font-heading font-800 mb-3">Klimaanlage anfragen</h2>
          <p class="text-white/80 mb-6">Unverbindliche Beratung und Angebot — kostenlos und vor Ort.</p>
          <a href={telHref} class="inline-flex items-center gap-2 bg-white text-[var(--color-primary-text)] font-bold px-6 py-3 rounded-xl hover:bg-yellow-50 transition-colors">
            {tel} anrufen
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
