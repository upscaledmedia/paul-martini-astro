---
import BaseLayout from '../../components/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const tel = '02651-4019589';
const telHref = 'tel:+4926514019589';
const email = 'info@paul-martini.de';
---

<BaseLayout
  title="Klimaanlage installieren Mayen | Paul Martini Sanitär"
  description="Klimaanlage kaufen & installieren lassen in Mayen — energieeffizient, leise, günstig. Daikin, Mitsubishi. ☎ 02651-4019589"
  canonical="/leistungen/klimatechnik/"
>
  <Header />

  <main class="pt-16 sm:pt-20">

    <!-- Hero -->
    <section class="relative bg-[var(--color-secondary)] py-20 sm:py-28 overflow-hidden" aria-labelledby="page-heading">
      <div class="absolute inset-0">
        <img
          src="/images/klima-hero.jpg"
          alt="Klimaanlage Inneneinheit an der Wand"
          class="w-full h-full object-cover opacity-20"
          width="1200"
          height="800"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-secondary)] via-[var(--color-secondary)]/80 to-transparent"></div>
      </div>
      <div class="relative max-w-5xl mx-auto px-4 sm:px-6">
        <div class="max-w-2xl">
          <span class="inline-block bg-[var(--color-accent)] text-white text-sm font-semibold px-4 py-1.5 rounded-full mb-6">Klimatechnik</span>
          <h1 id="page-heading" class="text-white mb-5">
            Klimaanlage installieren<br />
            <span class="text-[var(--color-accent-light)]">in Mayen & Polch</span>
          </h1>
          <p class="text-white/75 text-lg leading-relaxed mb-8">
            Kühlen im Sommer, heizen im Winter — moderne Klimaanlagen der neuesten Generation.
            Energiesparend, leise und professionell installiert von Ihrem SHK-Fachbetrieb.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href={telHref} class="inline-flex items-center justify-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold px-7 py-4 rounded-xl transition-colors text-lg">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
              </svg>
              Jetzt anrufen
            </a>
            <a href="/kontakt/" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-7 py-4 rounded-xl transition-colors text-lg border border-white/20">
              Angebot anfragen
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Bar -->
    <section class="bg-[var(--color-primary)] py-4" aria-label="Partnermarken">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="flex flex-wrap justify-center gap-6 sm:gap-10 text-white text-sm font-semibold text-center">
          <span>✓ Daikin Partner</span>
          <span>✓ Mitsubishi Electric</span>
          <span>✓ Meisterbetrieb</span>
          <span>✓ F-Gase-Zertifizierung</span>
        </div>
      </div>
    </section>

    <!-- Leistungen -->
    <section class="py-20 sm:py-24 bg-white" aria-labelledby="leistungen-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-14 fade-up">
          <span class="inline-block bg-[var(--color-primary)]/10 text-[var(--color-primary-text)] font-semibold text-sm px-4 py-1.5 rounded-full mb-4">Klimatechnik-Leistungen</span>
          <h2 id="leistungen-heading" class="mb-3">Was wir für Sie tun</h2>
          <p class="text-[var(--color-text-muted)] max-w-xl mx-auto">
            Von der Beratung bis zur Wartung — alles aus einer Hand, fachgerecht und herstellerzertifiziert.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 gap-6">
          {[
            {
              titel: 'Split-Klimaanlagen',
              text: 'Effiziente Innen- und Außengeräte für Wohnräume, Schlafzimmer und Büros. Kühlen und heizen in einem Gerät — energieeffizient und leise.',
            },
            {
              titel: 'Multi-Split-Systeme',
              text: 'Ein Außengerät versorgt mehrere Innenräume. Ideal für größere Häuser oder Bürogebäude mit mehreren Räumen.',
            },
            {
              titel: 'Luftreinigung & Filtration',
              text: 'Moderne Klimaanlagen reinigen die Raumluft. Ideal für Allergiker und Personen mit Atemwegsempfindlichkeiten.',
            },
            {
              titel: 'Installation & Inbetriebnahme',
              text: 'Fachgerechter Einbau nach Herstellervorgaben und geltenden F-Gase-Verordnungen. Vollständige Inbetriebnahme und Einweisung inklusive.',
            },
            {
              titel: 'Wartung & Service',
              text: 'Regelmäßige Wartungsverträge verlängern die Lebensdauer und erhalten die Effizienz. Wir erinnern Sie rechtzeitig.',
            },
            {
              titel: 'Beratung & Planung',
              text: 'Wir berechnen die richtige Leistung für Ihr Objekt und empfehlen das optimale System — keine Over- oder Undersizing.',
            },
          ].map((l, i) => (
            <div class="bg-[var(--color-surface)] rounded-xl p-7 fade-up" style={`transition-delay: ${i * 60}ms`}>
              <h3 class="font-heading font-700 text-[var(--color-text)] text-lg mb-3">{l.titel}</h3>
              <p class="text-[var(--color-text-muted)] leading-relaxed">{l.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Vorteile -->
    <section class="py-20 sm:py-24 bg-[var(--color-surface)]" aria-labelledby="vorteile-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="fade-up">
            <span class="inline-block bg-[var(--color-accent)]/10 text-[var(--color-accent)] font-semibold text-sm px-4 py-1.5 rounded-full mb-5">Klimaanlage lohnt sich</span>
            <h2 id="vorteile-heading" class="mb-6">Ihre Vorteile auf einen Blick</h2>
            <ul class="space-y-4">
              {[
                'Angenehme Raumtemperatur auch bei extremer Hitze',
                'Effizient heizen im Winter — besser als klassische Heizung',
                'Modernes Inverter-Gerät: bis zu 5x mehr Wärme als Strom verbraucht',
                'Leise Geräusche — auch im Schlafzimmer geeignet',
                'App-Steuerung für maximalen Komfort',
                'Luftfilterung für bessere Raumluftqualität',
              ].map(v => (
                <li class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" class="text-[var(--color-accent)] shrink-0 mt-0.5" aria-hidden="true">
                    <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-[var(--color-text)]">{v}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm fade-up">
            <h3 class="font-heading font-800 text-[var(--color-text)] text-xl mb-4">Kostenlos beraten lassen</h3>
            <p class="text-[var(--color-text-muted)] mb-6 leading-relaxed">
              Wir ermitteln kostenlos die passende Klimaanlage für Ihr Objekt.
              Unverbindlich vor Ort oder am Telefon.
            </p>
            <div class="space-y-3">
              <a href={telHref} class="flex items-center gap-3 bg-[var(--color-primary)] hover:bg-[var(--color-secondary)] text-white font-bold px-6 py-4 rounded-xl transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
                </svg>
                {tel} anrufen
              </a>
              <a href={`mailto:${email}?subject=Klimaanlage%20anfragen`} class="flex items-center gap-3 bg-[var(--color-surface)] hover:bg-[var(--color-border)] text-[var(--color-text)] font-semibold px-6 py-4 rounded-xl transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
                E-Mail schreiben
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 sm:py-24 bg-white" aria-labelledby="faq-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12 fade-up">
          <h2 id="faq-heading" class="mb-3">Häufige Fragen zur Klimaanlage</h2>
        </div>
        <div class="space-y-4">
          {[
            {
              frage: 'Was kostet eine Klimaanlage inklusive Einbau?',
              antwort: 'Ein Split-Gerät für einen Raum kostet inkl. Einbau ab ca. 1.500–2.500 €. Multi-Split-Systeme für mehrere Räume ab ca. 3.000 €. Gerne erstellen wir Ihnen ein genaues Angebot.',
            },
            {
              frage: 'Wie lange dauert die Installation einer Klimaanlage?',
              antwort: 'Eine Standard-Installation dauert in der Regel 4–8 Stunden pro Innengerät. Multi-Split-Systeme mit mehreren Geräten benötigen meist 1–2 Tage.',
            },
            {
              frage: 'Brauche ich für eine Klimaanlage eine Genehmigung?',
              antwort: 'In der Regel ist keine Baugenehmigung nötig. Bei denkmalgeschützten Gebäuden oder bestimmten Fassadensituationen kann eine Absprache mit der Gemeinde sinnvoll sein. Wir beraten Sie dazu.',
            },
            {
              frage: 'Wie oft muss eine Klimaanlage gewartet werden?',
              antwort: 'Wir empfehlen eine jährliche Wartung — idealerweise im Frühjahr vor der Kühlsaison. Die Wartung sichert die Effizienz, verlängert die Lebensdauer und ist für Gewährleistungsansprüche meist vorgeschrieben.',
            },
            {
              frage: 'Kann eine Klimaanlage auch heizen?',
              antwort: 'Ja, moderne Klimaanlagen (Wärmepumpen-Klimageräte) können sehr effizient heizen — oft 3–5x effizienter als klassische Elektroheizungen. Im Winter sind sie eine hervorragende Ergänzung zur bestehenden Heizung.',
            },
          ].map((q, i) => (
            <details class="bg-[var(--color-surface)] rounded-xl overflow-hidden fade-up group" style={`transition-delay: ${i * 60}ms`}>
              <summary class="px-7 py-5 font-heading font-700 text-[var(--color-text)] cursor-pointer flex items-center justify-between gap-4 list-none hover:text-[var(--color-primary-text)] transition-colors">
                {q.frage}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="18" height="18" class="shrink-0 text-[var(--color-text-muted)] group-open:rotate-180 transition-transform" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <div class="px-7 pb-6 text-[var(--color-text-muted)] leading-relaxed">
                {q.antwort}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-[var(--color-primary)]" aria-labelledby="cta-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 id="cta-heading" class="text-white mb-4">Klimaanlage anfragen</h2>
        <p class="text-white/80 text-lg mb-8">
          Jetzt anrufen — kostenlose Beratung und Angebot.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={telHref} class="inline-flex items-center justify-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold px-8 py-4 rounded-xl transition-colors text-lg">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="20" height="20" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
            </svg>
            {tel} anrufen
          </a>
          <a href="/kontakt/" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-4 rounded-xl transition-colors text-lg border border-white/20">
            Online anfragen
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
