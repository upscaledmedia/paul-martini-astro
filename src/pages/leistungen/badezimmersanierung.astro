---
import BaseLayout from '../../components/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const tel = '02651-4019589';
const telHref = 'tel:+4926514019589';
const email = 'info@paul-martini.de';
---

<BaseLayout
  title="Badezimmersanierung Mayen | Paul Martini Sanitär"
  description="Professionelle Badezimmersanierung in Mayen und Umgebung — von der Planung bis zur Übergabe. Barrierefrei, modern & auf Maß. ☎ 02651-4019589"
  canonical="/leistungen/badezimmersanierung/"
>
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Badezimmersanierung",
      "provider": {
        "@type": "LocalBusiness",
        "name": "Paul Martini Sanitär",
        "telephone": "+4926514019589",
        "areaServed": "Mayen"
      },
      "areaServed": ["Mayen", "Polch", "Andernach", "Kehrig"]
    })}</script>
  </Fragment>

  <Header />

  <main class="pt-16 sm:pt-20">

    <!-- Hero -->
    <section class="relative bg-[var(--color-secondary)] py-20 sm:py-28 overflow-hidden" aria-labelledby="page-heading">
      <div class="absolute inset-0">
        <img
          src="/images/bad-hero.jpg"
          alt="Modernes Badezimmer nach der Sanierung"
          class="w-full h-full object-cover opacity-25"
          width="1200"
          height="800"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-secondary)] via-[var(--color-secondary)]/80 to-transparent"></div>
      </div>
      <div class="relative max-w-5xl mx-auto px-4 sm:px-6">
        <div class="max-w-2xl">
          <span class="inline-block bg-[var(--color-accent)] text-white text-sm font-semibold px-4 py-1.5 rounded-full mb-6">Badsanierung</span>
          <h1 id="page-heading" class="text-white mb-5">
            Badezimmersanierung<br />
            <span class="text-[var(--color-accent-light)]">in Mayen & Umgebung</span>
          </h1>
          <p class="text-white/75 text-lg leading-relaxed mb-8">
            Wir sanieren Ihr Badezimmer von Grund auf — pünktlich, sauber und genau nach Ihren Vorstellungen.
            Als Fachbetrieb bei Mayen sind wir Ihr verlässlicher Partner für das neue Traumbad.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href={telHref} class="inline-flex items-center justify-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold px-7 py-4 rounded-xl transition-colors text-lg">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
              </svg>
              Kostenlos anfragen
            </a>
            <a href="/kontakt/" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-7 py-4 rounded-xl transition-colors text-lg border border-white/20">
              Angebot anfordern
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Leistungen -->
    <section class="py-20 sm:py-24 bg-white" aria-labelledby="leistungen-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-14 fade-up">
          <span class="inline-block bg-[var(--color-primary)]/10 text-[var(--color-primary-text)] font-semibold text-sm px-4 py-1.5 rounded-full mb-4">Unsere Badsanierung</span>
          <h2 id="leistungen-heading" class="mb-3">Alles aus einer Hand</h2>
          <p class="text-[var(--color-text-muted)] max-w-xl mx-auto">
            Von der ersten Beratung bis zur finalen Übergabe — wir koordinieren alle Gewerke und halten Termine ein.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            {
              titel: 'Komplettbad-Sanierung',
              text: 'Wir planen und realisieren Ihre komplette Badsanierung — Demontage, Rohbau, Fliesen, Sanitär, alles aus einer Hand.',
            },
            {
              titel: 'Barrierefreies Bad',
              text: 'Ebenerdige Duschen, Haltegriffe und rollstuhlgerechte Lösungen. Zukunftssicher und förderungsfähig über KfW.',
            },
            {
              titel: 'Modernisierung & Aufwertung',
              text: 'Neues Design, neue Fliesen, neue Sanitärobjekte — wir machen Ihr Bad wieder zeitgemäß und wertvoll.',
            },
            {
              titel: 'Fliesen & Bodenbelag',
              text: 'Professionelle Fliesenarbeiten in allen Formaten und Designs. Großformatfliesen, Mosaik, Naturstein.',
            },
            {
              titel: 'Sanitärobjekte',
              text: 'Waschtisch, WC, Dusche, Badewanne — alle führenden Marken. Wir beraten Sie bei der Auswahl und installieren fachgerecht.',
            },
            {
              titel: 'Badheizung',
              text: 'Beheizter Handtuchhalter, elektrische Fußbodenheizung oder Wasserführung — wir sorgen für wohlige Wärme im Bad.',
            },
          ].map((l, i) => (
            <div class="bg-[var(--color-surface)] rounded-xl p-7 fade-up" style={`transition-delay: ${i * 60}ms`}>
              <h3 class="font-heading font-700 text-[var(--color-text)] text-lg mb-3">{l.titel}</h3>
              <p class="text-[var(--color-text-muted)] leading-relaxed">{l.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Ablauf -->
    <section class="py-20 sm:py-24 bg-[var(--color-surface)]" aria-labelledby="ablauf-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="fade-up">
            <span class="inline-block bg-[var(--color-accent)]/10 text-[var(--color-accent)] font-semibold text-sm px-4 py-1.5 rounded-full mb-5">Unser Ablauf</span>
            <h2 id="ablauf-heading" class="mb-6">So läuft Ihre Badsanierung ab</h2>
            <div class="space-y-6">
              {[
                { num: '1', titel: 'Beratung vor Ort', text: 'Wir kommen zu Ihnen, schauen sich das Bad an und beraten kostenlos.' },
                { num: '2', titel: 'Angebot & Planung', text: 'Sie erhalten ein detailliertes Festpreisangebot. Keine versteckten Kosten.' },
                { num: '3', titel: 'Terminplanung', text: 'Wir koordinieren alle Gewerke und teilen Ihnen klare Zeitfenster mit.' },
                { num: '4', titel: 'Saubere Ausführung', text: 'Wir arbeiten sauber und zügig. Täglich Aufräumen inklusive.' },
                { num: '5', titel: 'Übergabe & Fertig', text: 'Abnahme gemeinsam, alle Mängel sofort behoben — dann genießen Sie Ihr neues Bad.' },
              ].map(s => (
                <div class="flex items-start gap-4">
                  <span class="w-9 h-9 rounded-full bg-[var(--color-primary)] text-white text-sm font-bold flex items-center justify-center shrink-0">{s.num}</span>
                  <div>
                    <h3 class="font-heading font-700 text-[var(--color-text)] mb-1">{s.titel}</h3>
                    <p class="text-[var(--color-text-muted)] text-sm">{s.text}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm fade-up">
            <h3 class="font-heading font-800 text-[var(--color-text)] text-xl mb-4">Beratung anfragen</h3>
            <p class="text-[var(--color-text-muted)] mb-6 leading-relaxed">
              Wir kommen zu Ihnen — kostenlos und unverbindlich. Teilen Sie uns einfach mit,
              was Sie sich vorstellen.
            </p>
            <div class="space-y-3">
              <a href={telHref} class="flex items-center gap-3 bg-[var(--color-primary)] hover:bg-[var(--color-secondary)] text-white font-bold px-6 py-4 rounded-xl transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
                </svg>
                {tel} anrufen
              </a>
              <a href={`mailto:${email}?subject=Badsanierung%20anfragen`} class="flex items-center gap-3 bg-[var(--color-surface)] hover:bg-[var(--color-border)] text-[var(--color-text)] font-semibold px-6 py-4 rounded-xl transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
                E-Mail schreiben
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 sm:py-24 bg-white" aria-labelledby="faq-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12 fade-up">
          <h2 id="faq-heading" class="mb-3">Häufige Fragen zur Badsanierung</h2>
        </div>
        <div class="space-y-4">
          {[
            {
              frage: 'Was kostet eine komplette Badsanierung?',
              antwort: 'Die Kosten hängen stark von Größe, Ausstattung und Zustand des Bades ab. Ein kleines Bad (ca. 5 m²) beginnt bei rund 8.000 €, für größere Bäder mit hochwertiger Ausstattung sind 15.000–25.000 € realistisch. Wir geben Ihnen ein genaues Festpreisangebot nach der Besichtigung.',
            },
            {
              frage: 'Wie lange dauert eine Badsanierung?',
              antwort: 'Eine typische Komplettsanierung dauert 2–3 Wochen. Kleinere Modernisierungen sind oft in 1 Woche erledigt. Wir teilen Ihnen im Vorfeld einen genauen Zeitplan mit.',
            },
            {
              frage: 'Werden Fördergelder für barrierefreie Bäder gezahlt?',
              antwort: 'Ja, die KfW fördert Barrierereduzierungen mit zinsgünstigen Krediten und Zuschüssen (Programm 455-B). Auch Pflegekassen können sich an den Kosten beteiligen. Wir informieren Sie gerne genauer.',
            },
            {
              frage: 'Können Sie auch nur einzelne Teile modernisieren?',
              antwort: 'Ja, wir machen auch Teilsanierungen — z.B. nur die Dusche erneuern, neue Fliesen verlegen oder nur die Sanitärobjekte tauschen. Wir beraten Sie, was sinnvoll ist.',
            },
            {
              frage: 'Müssen wir während der Sanierung ausziehen?',
              antwort: 'Das ist meistens nicht nötig. Wir planen die Arbeiten so, dass Sie weiterhin im Haus wohnen können. Falls Sie nur ein Bad haben, besprechen wir gemeinsam eine Lösung.',
            },
          ].map((q, i) => (
            <details class="bg-[var(--color-surface)] rounded-xl overflow-hidden fade-up group" style={`transition-delay: ${i * 60}ms`}>
              <summary class="px-7 py-5 font-heading font-700 text-[var(--color-text)] cursor-pointer flex items-center justify-between gap-4 list-none hover:text-[var(--color-primary-text)] transition-colors">
                {q.frage}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="18" height="18" class="shrink-0 text-[var(--color-text-muted)] group-open:rotate-180 transition-transform" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <div class="px-7 pb-6 text-[var(--color-text-muted)] leading-relaxed">
                {q.antwort}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-[var(--color-primary)]" aria-labelledby="cta-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 id="cta-heading" class="text-white mb-4">Ihr Traumbad — wir machen es möglich</h2>
        <p class="text-white/80 text-lg mb-8">
          Kostenlose Beratung vor Ort — unverbindlich und ohne Druck.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={telHref} class="inline-flex items-center justify-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold px-8 py-4 rounded-xl transition-colors text-lg">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="20" height="20" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
            </svg>
            {tel} anrufen
          </a>
          <a href="/kontakt/" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-4 rounded-xl transition-colors text-lg border border-white/20">
            Online anfragen
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
