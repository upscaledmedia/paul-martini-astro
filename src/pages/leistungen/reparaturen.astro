---
import BaseLayout from '../../components/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const tel = '02651-4019589';
const telHref = 'tel:+4926514019589';
---

<BaseLayout
  title="Sanitär Reparatur Mayen | Rohrbruch & Notfall | Paul Martini"
  description="Schnelle Sanitär-Reparaturen in Mayen — Rohrbruch, Heizungsausfall, Verstopfung. Zuverlässig und fair. ☎ 02651-4019589"
  canonical="/leistungen/reparaturen/"
>
  <Header />

  <main class="pt-16 sm:pt-20">
    <section class="bg-[var(--color-secondary)] py-16 sm:py-24 text-center text-white" aria-labelledby="page-heading">
      <div class="max-w-3xl mx-auto px-4">
        <span class="inline-block bg-[var(--color-accent)]/20 text-[var(--color-accent-light)] text-sm px-4 py-1.5 rounded-full mb-4">Schnelle Hilfe</span>
        <h1 id="page-heading" class="text-white mb-4">Sanitär-Reparaturen<br /><span class="text-[var(--color-accent-light)]">in Mayen & Umgebung</span></h1>
        <p class="text-white/75 text-lg max-w-2xl mx-auto">
          Rohrbruch, verstopfte Leitung oder Heizungsausfall — wir kommen schnell und helfen zuverlässig.
          Rufen Sie uns an!
        </p>
        <div class="mt-8">
          <a href={telHref} class="inline-flex items-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold text-xl px-8 py-4 rounded-xl transition-colors">
            Jetzt anrufen: {tel}
          </a>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="grid sm:grid-cols-2 gap-8 mb-12">
          {[
            { titel: 'Rohrbruch', text: 'Schnelle Ortung und Reparatur bei Wasserrohrbrüchen. Wir minimieren den Schaden.' },
            { titel: 'Heizungsreparatur', text: 'Heizung ausgefallen? Wir diagnostizieren und reparieren alle gängigen Heizsysteme.' },
            { titel: 'Rohrverstopfung', text: 'Professionelle Rohrreinigung bei hartnäckigen Verstopfungen.' },
            { titel: 'Versicherungsschäden', text: 'Wir unterstützen Sie bei der Schadensabwicklung mit Ihrer Versicherung.' },
          ].map(l => (
            <div class="bg-[var(--color-surface)] rounded-xl p-6">
              <h3 class="font-heading font-700 text-[var(--color-text)] mb-2">{l.titel}</h3>
              <p class="text-[var(--color-text-muted)] text-sm">{l.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
