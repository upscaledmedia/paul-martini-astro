---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Karriere | Paul Martini Sanitär · Jobs in Mayen"
  description="Wir suchen Verstärkung! Anlagenmechaniker/in SHK (m/w/d) in Kehrig bei Mayen. Familienbetrieb, faires Gehalt, sicherer Arbeitsplatz. Jetzt bewerben!"
  canonical="/karriere/"
>
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "JobPosting",
      "title": "Anlagenmechaniker/in SHK (m/w/d)",
      "description": "Wir suchen einen Anlagenmechaniker SHK für unser Team in Kehrig bei Mayen. Vollzeit, unbefristet.",
      "datePosted": "2026-01-01",
      "employmentType": "FULL_TIME",
      "hiringOrganization": {
        "@type": "Organization",
        "name": "Paul Martini Sanitär - Heizung - Klima",
        "sameAs": "https://paul-martini.pages.dev",
        "logo": "https://paul-martini.pages.dev/favicon.svg"
      },
      "jobLocation": {
        "@type": "Place",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Polcher Straße 31",
          "addressLocality": "Kehrig",
          "postalCode": "56729",
          "addressRegion": "Rheinland-Pfalz",
          "addressCountry": "DE"
        }
      }
    })}</script>
  </Fragment>

  <Header />

  <main class="pt-16 sm:pt-20">

    <!-- Hero -->
    <section class="relative bg-[var(--color-secondary)] py-20 sm:py-28 overflow-hidden" aria-labelledby="karriere-heading">
      <div class="absolute inset-0">
        <img
          src="/images/karriere-hero.jpg"
          alt="SHK-Fachkraft bei der Arbeit"
          class="w-full h-full object-cover opacity-25"
          width="1920"
          height="600"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-secondary)] via-[var(--color-secondary)]/80 to-transparent"></div>
      </div>
      <div class="relative max-w-5xl mx-auto px-4 sm:px-6">
        <div class="max-w-2xl">
          <span class="inline-block bg-[var(--color-accent)] text-white text-sm font-semibold px-4 py-1.5 rounded-full mb-6">Wir stellen ein</span>
          <h1 id="karriere-heading" class="text-white mb-6">
            Werde Teil unseres<br />
            <span class="text-[var(--color-accent-light)]">Teams bei Mayen</span>
          </h1>
          <p class="text-white/75 text-lg leading-relaxed mb-8">
            Wir sind ein wachsender Familienbetrieb und suchen handwerklich begabte Menschen mit Leidenschaft.
            Bei uns bist du kein Rädchen in der Maschine — sondern ein wichtiger Teil des Teams.
          </p>
          <a href="#stelle-anlagenmechaniker" class="inline-flex items-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold px-7 py-4 rounded-xl transition-colors text-lg">
            Offene Stelle ansehen
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="18" height="18" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="py-20 sm:py-24 bg-white" aria-labelledby="benefits-heading">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-14 fade-up">
          <span class="inline-block bg-[var(--color-primary)]/10 text-[var(--color-primary-text)] font-semibold text-sm px-4 py-1.5 rounded-full mb-4">Warum Paul Martini?</span>
          <h2 id="benefits-heading" class="mb-3">Was wir dir bieten</h2>
          <p class="text-[var(--color-text-muted)] max-w-xl mx-auto">
            Wir glauben, dass zufriedene Mitarbeiter die beste Arbeit machen. Deshalb kümmern wir uns um dich.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            {
              icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
              titel: 'Faires Gehalt',
              text: 'Leistungsgerechte Bezahlung nach Tarif plus Prämien. Wir zahlen pünktlich und transparent.'
            },
            {
              icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
              titel: 'Sicherer Arbeitsplatz',
              text: 'Unbefristeter Vertrag von Anfang an. Wir wachsen — und wachsen gerne mit dir zusammen.'
            },
            {
              icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>`,
              titel: 'Familiäres Team',
              text: 'Kleines, eingespieltes Team. Kurze Entscheidungswege, offene Kommunikation, echter Zusammenhalt.'
            },
            {
              icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>`,
              titel: 'Weiterbildung',
              text: 'Wir fördern deine Entwicklung — Lehrgänge, Herstellerschulungen, Meisterkurs. Wer wachsen will, wird unterstützt.'
            },
            {
              icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>`,
              titel: 'Modernes Werkzeug',
              text: 'Neues Fahrzeug, hochwertiges Werkzeug, moderne Messtechnik. Du arbeitest mit dem Besten, was es gibt.'
            },
            {
              icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>`,
              titel: 'Region Mayen',
              text: 'Keine langen Anfahrten. Du arbeitest in deiner Heimatregion — Mayen, Polch, Andernach und Umgebung.'
            },
          ].map((b, i) => (
            <div class="flex gap-4 bg-[var(--color-surface)] rounded-2xl p-6 fade-up" style={`transition-delay: ${i * 60}ms`}>
              <div class="w-14 h-14 bg-[var(--color-primary)]/10 rounded-xl flex items-center justify-center shrink-0 text-[var(--color-primary-text)]">
                <Fragment set:html={b.icon} />
              </div>
              <div>
                <h3 class="font-heading font-700 text-[var(--color-text)] text-base mb-1">{b.titel}</h3>
                <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">{b.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stellenanzeige -->
    <section id="stelle-anlagenmechaniker" class="py-20 sm:py-28 bg-[var(--color-surface)]" aria-labelledby="stelle-heading">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12 fade-up">
          <span class="inline-block bg-[var(--color-accent)]/10 text-[var(--color-accent)] font-semibold text-sm px-4 py-1.5 rounded-full mb-4">Offene Stelle</span>
          <h2 id="stelle-heading" class="mb-3">Anlagenmechaniker/in SHK (m/w/d)</h2>
          <p class="text-[var(--color-text-muted)] text-lg">Vollzeit · Kehrig bei Mayen · Unbefristet</p>
        </div>

        <div class="bg-white rounded-2xl shadow-sm overflow-hidden fade-up">
          <div class="bg-[var(--color-primary)] px-8 py-6">
            <h3 class="text-white font-heading font-800 text-xl">Deine Aufgaben</h3>
          </div>
          <div class="px-8 py-6">
            <ul class="space-y-3">
              {[
                'Installation und Montage von Sanitäranlagen, Heizungssystemen und Klimaanlagen',
                'Wartung, Instandhaltung und Reparatur bestehender Anlagen',
                'Wärmepumpen-Installation und Inbetriebnahme',
                'Badsanierungen — von der Demontage bis zur Übergabe',
                'Kundenberatung vor Ort mit Empfehlungen zur Modernisierung',
                'Dokumentation der ausgeführten Arbeiten',
              ].map(p => (
                <li class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" class="text-[var(--color-primary-text)] shrink-0 mt-0.5" aria-hidden="true">
                    <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-[var(--color-text-muted)]">{p}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm overflow-hidden fade-up mt-6">
          <div class="bg-[var(--color-secondary)] px-8 py-6">
            <h3 class="text-white font-heading font-800 text-xl">Was du mitbringst</h3>
          </div>
          <div class="px-8 py-6">
            <ul class="space-y-3">
              {[
                'Abgeschlossene Ausbildung als Anlagenmechaniker/in SHK oder vergleichbare Qualifikation',
                'Erfahrung im SHK-Handwerk (Berufseinsteiger willkommen)',
                'Handwerkliches Geschick und selbstständige Arbeitsweise',
                'Freundliches Auftreten im Kundenkontakt',
                'Führerschein Klasse B',
                'Zuverlässigkeit und Teamgeist',
              ].map(p => (
                <li class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" class="text-[var(--color-accent)] shrink-0 mt-0.5" aria-hidden="true">
                    <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-[var(--color-text-muted)]">{p}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Initiativbewerbung + Bewerbungs-CTA -->
    <section class="py-20 sm:py-24 bg-[var(--color-secondary)]" aria-labelledby="bewerben-heading">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="grid sm:grid-cols-2 gap-8">

          <!-- Bewerbung für offene Stelle -->
          <div class="bg-white/5 rounded-2xl p-8 fade-up">
            <div class="w-14 h-14 bg-[var(--color-accent)]/20 rounded-xl flex items-center justify-center mb-5 text-[var(--color-accent-light)]">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
              </svg>
            </div>
            <h3 id="bewerben-heading" class="text-white font-heading font-700 text-xl mb-3">Jetzt bewerben</h3>
            <p class="text-white/60 text-sm mb-6 leading-relaxed">
              Schick uns deine Bewerbung per E-Mail — Lebenslauf und kurzes Anschreiben reichen uns völlig aus.
            </p>
            <a
              href="mailto:basti.martini@web.de?subject=Bewerbung%20Anlagenmechaniker%20SHK"
              class="inline-flex items-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold px-6 py-3 rounded-xl transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
              Per E-Mail bewerben
            </a>
          </div>

          <!-- Initiativbewerbung -->
          <div class="bg-white/5 rounded-2xl p-8 fade-up" style="transition-delay: 100ms">
            <div class="w-14 h-14 bg-[var(--color-primary)]/20 rounded-xl flex items-center justify-center mb-5 text-[var(--color-primary-light)]">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              </svg>
            </div>
            <h3 class="text-white font-heading font-700 text-xl mb-3">Initiativbewerbung</h3>
            <p class="text-white/60 text-sm mb-6 leading-relaxed">
              Du passt nicht exakt auf die Stelle, aber willst trotzdem Teil unseres Teams werden?
              Wir freuen uns über Initiativbewerbungen — einfach anrufen oder schreiben.
            </p>
            <a
              href="tel:+4926514019589"
              class="inline-flex items-center gap-2 border border-white/30 hover:border-white/60 text-white font-semibold px-6 py-3 rounded-xl transition-colors hover:bg-white/5"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
              </svg>
              02651-4019589 anrufen
            </a>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
