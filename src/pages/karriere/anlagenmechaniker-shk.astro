---
import BaseLayout from '../../components/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const tel = '02651-4019589';
const telHref = 'tel:+4926514019589';
const email = 'info@paul-martini.de';
---

<BaseLayout
  title="Anlagenmechaniker/in SHK (m/w/d) | Paul Martini Sanitär · Mayen"
  description="Job als Anlagenmechaniker SHK in Kehrig bei Mayen. Unbefristet, fairer Lohn, Familienbetrieb. Jetzt bewerben bei Paul Martini Sanitär!"
  canonical="/karriere/anlagenmechaniker-shk/"
>
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "JobPosting",
      "title": "Anlagenmechaniker/in SHK (m/w/d)",
      "description": "Wir suchen einen erfahrenen Anlagenmechaniker SHK für unser Team in Kehrig bei Mayen. Vollzeit, unbefristet. Installation und Wartung von Sanitär-, Heizungs- und Klimaanlagen.",
      "datePosted": "2026-01-01",
      "validThrough": "2026-12-31",
      "employmentType": "FULL_TIME",
      "hiringOrganization": {
        "@type": "Organization",
        "name": "Paul Martini Sanitär - Heizung - Klima",
        "sameAs": "https://paul-martini.pages.dev",
        "logo": "https://paul-martini.pages.dev/favicon.svg"
      },
      "jobLocation": {
        "@type": "Place",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Polcher Straße 31",
          "addressLocality": "Kehrig",
          "postalCode": "56729",
          "addressRegion": "Rheinland-Pfalz",
          "addressCountry": "DE"
        }
      },
      "baseSalary": {
        "@type": "MonetaryAmount",
        "currency": "EUR",
        "value": {
          "@type": "QuantitativeValue",
          "minValue": 2800,
          "maxValue": 3800,
          "unitText": "MONTH"
        }
      }
    })}</script>
  </Fragment>

  <Header />

  <main class="pt-16 sm:pt-20">

    <!-- Hero -->
    <section class="relative bg-[var(--color-secondary)] py-20 sm:py-28 overflow-hidden" aria-labelledby="job-heading">
      <div class="absolute inset-0">
        <img
          src="/images/karriere-team.jpg"
          alt="SHK-Fachkraft bei der Arbeit"
          class="w-full h-full object-cover opacity-20"
          width="1920"
          height="600"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-secondary)] via-[var(--color-secondary)]/85 to-transparent"></div>
      </div>
      <div class="relative max-w-5xl mx-auto px-4 sm:px-6">
        <div class="max-w-2xl">
          <div class="flex items-center gap-3 mb-6">
            <span class="inline-block bg-[var(--color-accent)] text-white text-sm font-semibold px-4 py-1.5 rounded-full">Jetzt offen</span>
            <span class="text-white/60 text-sm">Vollzeit · Unbefristet</span>
          </div>
          <h1 id="job-heading" class="text-white mb-4">
            Anlagenmechaniker/in SHK<br />
            <span class="text-[var(--color-accent-light)]">(m/w/d) in Kehrig</span>
          </h1>
          <p class="text-white/75 text-lg leading-relaxed mb-8">
            Wir sind ein wachsender Familienbetrieb im Raum Mayen-Koblenz und suchen einen zuverlässigen
            Anlagenmechaniker SHK. Du arbeitest in einem eingespielten Team mit modernster Ausrüstung.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href={`mailto:${email}?subject=Bewerbung%3A%20Anlagenmechaniker%20SHK`} class="inline-flex items-center justify-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold px-7 py-4 rounded-xl transition-colors text-lg">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
              Jetzt bewerben
            </a>
            <a href={telHref} class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-7 py-4 rounded-xl transition-colors text-lg border border-white/20">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
              </svg>
              {tel} anrufen
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Facts -->
    <section class="bg-[var(--color-accent)] py-5" aria-label="Eckdaten der Stelle">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-white text-center text-sm font-semibold">
          <div class="flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
            Kehrig bei Mayen
          </div>
          <div class="flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
            Vollzeit · 40h/Woche
          </div>
          <div class="flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
            Unbefristeter Vertrag
          </div>
          <div class="flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
            Ab 2.800 € / Monat
          </div>
        </div>
      </div>
    </section>

    <!-- Stellenbeschreibung -->
    <section class="py-20 sm:py-24 bg-white" aria-labelledby="aufgaben-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-3 gap-12">

          <!-- Linke Spalte: Aufgaben & Anforderungen -->
          <div class="lg:col-span-2 space-y-10">
            <div class="fade-up">
              <h2 id="aufgaben-heading" class="text-2xl font-heading font-800 text-[var(--color-text)] mb-6">Deine Aufgaben</h2>
              <ul class="space-y-3">
                {[
                  'Installation und Montage von Sanitäranlagen (Bäder, WC, Duschen)',
                  'Heizungsinstallation und Wartung (Gas, Öl, Wärmepumpe)',
                  'Klimatechnik und Lüftungsanlagen installieren und warten',
                  'Rohrleitungsbau und Druckleitungen verlegen',
                  'Fehlersuche, Reparaturen und Störungsbeseitigung',
                  'Kundendiensteinsätze und Wartungsverträge betreuen',
                  'Dokumentation und Protokollierung der Arbeiten',
                ].map(aufgabe => (
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" class="text-[var(--color-accent)] shrink-0 mt-0.5" aria-hidden="true">
                      <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-[var(--color-text)]">{aufgabe}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="fade-up">
              <h2 class="text-2xl font-heading font-800 text-[var(--color-text)] mb-6">Das bringst du mit</h2>
              <ul class="space-y-3">
                {[
                  'Abgeschlossene Ausbildung als Anlagenmechaniker/in SHK',
                  'Erste Berufserfahrung wünschenswert — Berufseinsteiger willkommen',
                  'Kenntnisse in Sanitär, Heizung und/oder Klima',
                  'Zuverlässigkeit, Teamgeist und Kundenfreundlichkeit',
                  'Führerschein Klasse B',
                  'Deutschkenntnisse für die Kommunikation mit Kunden',
                ].map(req => (
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" class="text-[var(--color-primary)] shrink-0 mt-0.5" aria-hidden="true">
                      <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-[var(--color-text)]">{req}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Rechte Spalte: Unternehmen & Bewerben -->
          <div class="space-y-6">
            <div class="bg-[var(--color-surface)] rounded-2xl p-6 fade-up">
              <h3 class="font-heading font-700 text-[var(--color-text)] mb-4">Über uns</h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed mb-4">
                Paul Martini Sanitär – Heizung – Klima ist ein etablierter Familienbetrieb in Kehrig bei Mayen.
                Wir versorgen die Region seit Jahren mit Top-Qualität im SHK-Bereich.
              </p>
              <dl class="space-y-2 text-sm">
                <div class="flex items-center gap-2">
                  <dt class="text-[var(--color-text-muted)]">Standort:</dt>
                  <dd class="text-[var(--color-text)] font-medium">Kehrig, 56729</dd>
                </div>
                <div class="flex items-center gap-2">
                  <dt class="text-[var(--color-text-muted)]">Branche:</dt>
                  <dd class="text-[var(--color-text)] font-medium">SHK / Handwerk</dd>
                </div>
                <div class="flex items-center gap-2">
                  <dt class="text-[var(--color-text-muted)]">Teamgröße:</dt>
                  <dd class="text-[var(--color-text)] font-medium">Familienbetrieb</dd>
                </div>
              </dl>
            </div>

            <div class="bg-[var(--color-primary)] rounded-2xl p-6 text-white fade-up">
              <h3 class="text-white font-heading font-700 text-lg mb-3">Jetzt bewerben</h3>
              <p class="text-white/80 text-sm mb-5">
                Schick uns deine Bewerbung per E-Mail oder ruf einfach an. Kein Anschreiben nötig — erzähl uns einfach von dir.
              </p>
              <a
                href={`mailto:${email}?subject=Bewerbung%3A%20Anlagenmechaniker%20SHK`}
                class="block text-center bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold px-5 py-3 rounded-xl transition-colors mb-3"
              >
                Per E-Mail bewerben
              </a>
              <a
                href={telHref}
                class="block text-center bg-white/10 hover:bg-white/20 text-white font-semibold px-5 py-3 rounded-xl transition-colors border border-white/20"
              >
                {tel} anrufen
              </a>
            </div>

            <a href="/karriere/" class="flex items-center gap-2 text-[var(--color-text-muted)] hover:text-[var(--color-primary-text)] text-sm transition-colors fade-up">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="16" height="16" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
              </svg>
              Alle Stellen ansehen
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="py-20 sm:py-24 bg-[var(--color-surface)]" aria-labelledby="benefits-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12 fade-up">
          <h2 id="benefits-heading" class="mb-3">Was wir dir bieten</h2>
          <p class="text-[var(--color-text-muted)]">Wir kümmern uns um unsere Mitarbeiter — fair, direkt und verlässlich.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            { icon: '💶', titel: 'Faires Gehalt', text: '2.800 – 3.800 € brutto/Monat je nach Erfahrung. Pünktlich und transparent.' },
            { icon: '📋', titel: 'Unbefristeter Vertrag', text: 'Sicherheit von Anfang an. Wir wachsen und wachsen gerne mit dir.' },
            { icon: '🚐', titel: 'Firmenwagen', text: 'Modernes Firmenfahrzeug für Einsätze im Raum Mayen-Koblenz.' },
            { icon: '🔧', titel: 'Top-Ausrüstung', text: 'Modernes Werkzeug und Messgeräte — wir investieren in unsere Leute.' },
            { icon: '🎓', titel: 'Weiterbildung', text: 'Schulungen bei führenden Herstellern wie Viessmann, Vaillant und Bosch.' },
            { icon: '👨‍👩‍👧', titel: 'Familiäres Team', text: 'Kurze Wege, direkte Kommunikation. Du bist kein Rädchen in der Maschine.' },
          ].map(b => (
            <div class="bg-white rounded-xl p-6 fade-up">
              <div class="text-3xl mb-3" aria-hidden="true">{b.icon}</div>
              <h3 class="font-heading font-700 text-[var(--color-text)] mb-2">{b.titel}</h3>
              <p class="text-[var(--color-text-muted)] text-sm">{b.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-16 bg-[var(--color-secondary)]" aria-labelledby="bewerbung-cta-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 id="bewerbung-cta-heading" class="text-white mb-4">Bereit für den nächsten Schritt?</h2>
        <p class="text-white/75 text-lg mb-8">
          Kein langes Bewerbungsverfahren — einfach anrufen oder E-Mail schicken. Wir freuen uns auf dich.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`mailto:${email}?subject=Bewerbung%3A%20Anlagenmechaniker%20SHK`} class="inline-flex items-center justify-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold px-8 py-4 rounded-xl transition-colors text-lg">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            Jetzt per E-Mail bewerben
          </a>
          <a href={telHref} class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-4 rounded-xl transition-colors text-lg border border-white/20">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
            </svg>
            {tel} anrufen
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
