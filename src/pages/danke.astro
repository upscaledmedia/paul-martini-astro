---
import BaseLayout from '../components/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Vielen Dank! | Paul Martini Sanitär"
  description="Ihre Anfrage wurde erfolgreich gesendet."
  noIndex={true}
>
  <main class="min-h-screen bg-[var(--color-surface)] flex items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <div class="w-20 h-20 bg-[var(--color-accent)]/10 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="36" height="36" class="text-[var(--color-accent)]" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
      </div>
      <h1 class="font-heading font-800 text-3xl text-[var(--color-text)] mb-4">Vielen Dank!</h1>
      <p class="text-[var(--color-text-muted)] text-lg mb-8">
        Ihre Anfrage ist bei uns eingegangen. Wir melden uns schnellstmöglich bei Ihnen.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white font-semibold px-6 py-3 rounded-xl transition-colors"
      >
        Zur Startseite
      </a>
    </div>
  </main>
</BaseLayout>
