---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const tel = '02651-4019589';
const telHref = 'tel:+4926514019589';
const email = 'basti.martini@web.de';
---

<BaseLayout
  title="Kontakt | Paul Martini Sanitär · Heizung · Klima Mayen"
  description="Kontaktieren Sie Paul Martini Sanitär in Kehrig bei Mayen. ☎ 02651-4019589 · Mo–Fr 7:45–16:00 Uhr. Kostenlose Beratung & Angebot."
  canonical="/kontakt/"
>
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "name": "Kontakt — Paul Martini Sanitär",
      "url": "https://paul-martini.pages.dev/kontakt/"
    })}</script>
  </Fragment>

  <Header />

  <main class="pt-16 sm:pt-20">
    <!-- Hero -->
    <section class="bg-[var(--color-surface)] py-16 sm:py-24 text-center" aria-labelledby="kontakt-heading">
      <div class="max-w-2xl mx-auto px-4">
        <span class="inline-block bg-[var(--color-primary)]/10 text-[var(--color-primary-text)] font-semibold text-sm px-4 py-1.5 rounded-full mb-4">Kontakt</span>
        <h1 id="kontakt-heading" class="mb-4">Wir sind für Sie da</h1>
        <p class="text-[var(--color-text-muted)] text-lg">
          Rufen Sie uns an oder schreiben Sie uns. Wir beraten Sie gerne und
          erstellen Ihnen ein kostenloses Angebot.
        </p>
      </div>
    </section>

    <!-- Kontaktmöglichkeiten + Formular -->
    <section class="py-16 sm:py-20 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12">
          <!-- Linke Seite: Infos -->
          <div>
            <h2 class="text-2xl font-heading font-700 mb-8">Kontaktinformationen</h2>

            <div class="space-y-6">
              <div class="flex gap-4">
                <div class="w-12 h-12 bg-[var(--color-primary)]/10 rounded-xl flex items-center justify-center text-[var(--color-primary)] shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-[var(--color-text)] mb-1">Telefon</h3>
                  <a href={telHref} class="text-[var(--color-primary-text)] font-semibold text-lg hover:underline">{tel}</a>
                  <p class="text-[var(--color-text-muted)] text-sm mt-1">Mo–Fr · 7:45–16:00 Uhr</p>
                </div>
              </div>

              <div class="flex gap-4">
                <div class="w-12 h-12 bg-[var(--color-primary)]/10 rounded-xl flex items-center justify-center text-[var(--color-primary)] shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-[var(--color-text)] mb-1">E-Mail</h3>
                  <a href={`mailto:${email}`} class="text-[var(--color-primary-text)] font-semibold hover:underline">{email}</a>
                </div>
              </div>

              <div class="flex gap-4">
                <div class="w-12 h-12 bg-[var(--color-primary)]/10 rounded-xl flex items-center justify-center text-[var(--color-primary)] shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-[var(--color-text)] mb-1">Adresse</h3>
                  <p class="text-[var(--color-text-muted)]">Polcher Straße 31<br />56729 Kehrig bei Mayen</p>
                </div>
              </div>
            </div>

            <div class="mt-8 p-5 bg-[var(--color-surface)] rounded-xl border border-[var(--color-border)]">
              <p class="text-[var(--color-text-muted)] text-sm">
                <strong class="text-[var(--color-text)]">Öffnungszeiten:</strong><br />
                Montag – Freitag: 7:45 – 16:00 Uhr<br />
                Samstag & Sonntag: Geschlossen
              </p>
            </div>
          </div>

          <!-- Rechte Seite: Formular -->
          <div>
            <h2 class="text-2xl font-heading font-700 mb-8">Anfrage schicken</h2>
            <form
              action="/danke/"
              method="POST"
              class="space-y-5"
              aria-label="Kontaktformular"
            >
              <div>
                <label for="name" class="block text-sm font-semibold text-[var(--color-text)] mb-1.5">Ihr Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  class="w-full border border-[var(--color-border)] rounded-lg px-4 py-3 text-[var(--color-text)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)] transition-colors text-sm"
                  placeholder="Max Mustermann"
                />
              </div>
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="telefon" class="block text-sm font-semibold text-[var(--color-text)] mb-1.5">Telefon *</label>
                  <input
                    type="tel"
                    id="telefon"
                    name="telefon"
                    required
                    autocomplete="tel"
                    class="w-full border border-[var(--color-border)] rounded-lg px-4 py-3 text-[var(--color-text)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)] transition-colors text-sm"
                    placeholder="02651 ..."
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-semibold text-[var(--color-text)] mb-1.5">E-Mail</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    autocomplete="email"
                    class="w-full border border-[var(--color-border)] rounded-lg px-4 py-3 text-[var(--color-text)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)] transition-colors text-sm"
                    placeholder="max@beispiel.de"
                  />
                </div>
              </div>
              <div>
                <label for="leistung" class="block text-sm font-semibold text-[var(--color-text)] mb-1.5">Gewünschte Leistung</label>
                <select
                  id="leistung"
                  name="leistung"
                  class="w-full border border-[var(--color-border)] rounded-lg px-4 py-3 text-[var(--color-text)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)] transition-colors text-sm"
                >
                  <option value="">Bitte wählen...</option>
                  <option>Badezimmersanierung</option>
                  <option>Heizung / Wärmepumpe</option>
                  <option>Klimaanlage</option>
                  <option>Reparatur / Notfall</option>
                  <option>Sonstiges</option>
                </select>
              </div>
              <div>
                <label for="nachricht" class="block text-sm font-semibold text-[var(--color-text)] mb-1.5">Ihre Nachricht *</label>
                <textarea
                  id="nachricht"
                  name="nachricht"
                  required
                  rows="5"
                  class="w-full border border-[var(--color-border)] rounded-lg px-4 py-3 text-[var(--color-text)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)] transition-colors text-sm resize-none"
                  placeholder="Beschreiben Sie kurz Ihr Anliegen..."
                ></textarea>
              </div>
              <p class="text-xs text-[var(--color-text-muted)]">
                Mit dem Absenden stimmen Sie unserer <a href="/datenschutz/" class="underline">Datenschutzerklärung</a> zu. *Pflichtfelder
              </p>
              <button
                type="submit"
                class="w-full bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold py-4 rounded-xl transition-colors text-lg"
              >
                Anfrage absenden
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
