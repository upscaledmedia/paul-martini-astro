---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const tel = '02651-4019589';
const telHref = 'tel:+4926514019589';
const email = 'basti.martini@web.de';
const adresse = 'Polcher Straße 31, 56729 Kehrig';

const leistungen = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" /></svg>`,
    titel: 'Badezimmersanierung',
    text: 'Komplette Badsanierungen — von der Planung bis zur Übergabe. Barrierefrei, modern und auf Wunsch auch energieeffizient.',
    href: '/leistungen/badezimmersanierung/',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" /></svg>`,
    titel: 'Heizung & Wärmepumpe',
    text: 'Moderne Heizsysteme, Wärmepumpen und Smart-Home-Integration. Wir helfen Ihnen, auf erneuerbare Energien umzusteigen.',
    href: '/leistungen/heizung/',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>`,
    titel: 'Klimatechnik',
    text: 'Energiesparende Klimaanlagen der neuesten Generation. Kühlen im Sommer, Heizen im Winter — effizient und leise.',
    href: '/leistungen/klimatechnik/',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" /></svg>`,
    titel: 'Reparaturen & Notdienst',
    text: 'Schnelle Reparaturen bei Rohrbruch, Heizungsausfall oder Verstopfung. Wir kümmern uns — zuverlässig und fair.',
    href: '/leistungen/reparaturen/',
  },
];

const reviews = [
  {
    name: 'Familie Hoffmann',
    ort: 'Mayen',
    text: 'Super Arbeit! Die Badsanierung wurde genau nach unseren Wünschen umgesetzt. Herr Martini erklärt alles verständlich und arbeitet sehr sauber. Absolut empfehlenswert!',
    sterne: 5,
  },
  {
    name: 'Klaus-Dieter W.',
    ort: 'Polch',
    text: 'Heizungsanlage komplett erneuert — alles reibungslos, pünktlich und zum vereinbarten Preis. Sehr freundliches Team. Gerne wieder.',
    sterne: 5,
  },
  {
    name: 'Petra M.',
    ort: 'Kehrig',
    text: 'Rohrbruch am Wochenende — kein Problem! Schnelle Reaktion, professionelle Reparatur. Man merkt, dass das ein echter Familienbetrieb mit Herz ist.',
    sterne: 5,
  },
];

const einzugsgebiet = [
  'Mayen', 'Polch', 'Andernach', 'Koblenz', 'Mendig', 'Ettringen',
  'Bell', 'Thür', 'Kottenheim', 'Münstermaifeld', 'Ochtendung', 'Plaidt',
  'Rieden', 'Nickenich', 'Bassenheim', 'Niederzissen',
];
---

<BaseLayout
  title="Paul Martini Sanitär · Heizung · Klima | Ihr Fachbetrieb bei Mayen"
  description="Ihr SHK-Fachbetrieb in Kehrig bei Mayen — Badezimmersanierung, Heizung, Wärmepumpe & Klimatechnik. ☎ 02651-4019589 | Familienbetrieb seit 3 Generationen."
>
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "LocalBusiness",
          "@id": "https://paul-martini.pages.dev/#business",
          "name": "Paul Martini Sanitär - Heizung - Klima",
          "description": "SHK-Fachbetrieb in Kehrig bei Mayen. Badezimmersanierung, Heizung, Wärmepumpe und Klimatechnik.",
          "url": "https://paul-martini.pages.dev",
          "telephone": "+4926514019589",
          "email": "basti.martini@web.de",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Polcher Straße 31",
            "addressLocality": "Kehrig",
            "postalCode": "56729",
            "addressCountry": "DE"
          },
          "areaServed": ["Mayen", "Polch", "Andernach", "Koblenz", "Mendig"],
          "openingHours": "Mo-Fr 07:45-16:00",
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "5.0",
            "reviewCount": "15"
          },
          "priceRange": "€€"
        },
        {
          "@type": "WebSite",
          "@id": "https://paul-martini.pages.dev/#website",
          "url": "https://paul-martini.pages.dev",
          "name": "Paul Martini Sanitär - Heizung - Klima"
        }
      ]
    })}</script>
  </Fragment>

  <Header />

  <main class="pt-16 sm:pt-20">

    <!-- ═══════════════════════════════════════════════
         §1 — HERO 1A FULLSCREEN
    ═══════════════════════════════════════════════ -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[var(--color-secondary)]" aria-label="Hero">
      <!-- Hero Background Image -->
      <div class="absolute inset-0" aria-hidden="true">
        <img src="/images/hero-bg.jpg" alt="" class="w-full h-full object-cover opacity-30" width="1920" height="1080" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-br from-[#0B1D35]/90 via-[#0D2B4A]/75 to-[#0A1628]/60"></div>
      </div>
      <!-- Decorative circles -->
      <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-[var(--color-primary)]/10 rounded-full blur-3xl" aria-hidden="true"></div>
      <div class="absolute bottom-1/4 left-1/4 w-64 h-64 bg-[var(--color-accent)]/10 rounded-full blur-3xl" aria-hidden="true"></div>

      <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 text-center pt-20 pb-16">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 text-white/90 text-sm font-medium mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16" class="text-[var(--color-accent-light)]" aria-hidden="true">
            <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
          </svg>
          5,0 bei Google · 15 Bewertungen · Familienbetrieb seit 3 Generationen
        </div>

        <h1 class="text-white mb-6">
          Ihr SHK-Fachbetrieb<br />
          <span class="text-[var(--color-accent-light)]">in Kehrig bei Mayen</span>
        </h1>

        <p class="text-white/75 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
          Badezimmersanierung, Heizungsmodernisierung und Klimatechnik —
          professionell und zuverlässig. <strong class="text-white">Wir kommen zu Ihnen.</strong>
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={telHref}
            class="inline-flex items-center justify-center gap-3 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold text-lg px-8 py-4 rounded-xl transition-all shadow-lg shadow-orange-900/30 hover:shadow-orange-900/50 hover:-translate-y-0.5"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="22" height="22" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
            </svg>
            {tel} anrufen
          </a>
          <a
            href="/kontakt/"
            class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white/60 text-white font-semibold text-lg px-8 py-4 rounded-xl transition-all hover:bg-white/10"
          >
            Anfrage stellen
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>

        <!-- Scroll hint -->
        <div class="mt-16 flex justify-center animate-bounce" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="24" height="24" class="text-white/40">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         §2 — VERTRAUENSLEISTE
    ═══════════════════════════════════════════════ -->
    <section class="bg-[var(--color-primary)] py-6" aria-label="Vertrauenssignale">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-white text-center">
          <div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28" class="text-[var(--color-accent)] shrink-0" aria-hidden="true">
              <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
            </svg>
            <div class="text-left">
              <div class="font-bold text-lg leading-tight">5,0 Sterne</div>
              <div class="text-white/80 text-xs">15 Google-Bewertungen</div>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28" class="shrink-0" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
            </svg>
            <div class="text-left">
              <div class="font-bold text-lg leading-tight">Meisterbetrieb</div>
              <div class="text-white/80 text-xs">Zertifizierter Fachbetrieb</div>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28" class="shrink-0" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
            </svg>
            <div class="text-left">
              <div class="font-bold text-lg leading-tight">3. Generation</div>
              <div class="text-white/80 text-xs">Familienbetrieb mit Tradition</div>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28" class="shrink-0" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <div class="text-left">
              <div class="font-bold text-lg leading-tight">Region Mayen</div>
              <div class="text-white/80 text-xs">Kehrig · Polch · Andernach</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         §4 — LEISTUNGEN GRID
    ═══════════════════════════════════════════════ -->
    <section id="leistungen" class="py-20 sm:py-28 bg-white" aria-labelledby="leistungen-heading">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-14 fade-up">
          <span class="inline-block bg-[var(--color-primary)]/10 text-[var(--color-primary-text)] font-semibold text-sm px-4 py-1.5 rounded-full mb-4">Unsere Leistungen</span>
          <h2 id="leistungen-heading" class="mb-4">
            Alles rund um Bad, Heizung &amp; Klima<br />
            <span class="text-[var(--color-primary-text)]">— aus einer Hand in Mayen</span>
          </h2>
          <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto text-lg">
            Als Fachbetrieb für Sanitär, Heizung und Klimatechnik bieten wir Ihnen
            alle Leistungen rund ums Haus — zuverlässig, pünktlich und zu fairen Preisen.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {leistungen.map((l, i) => (
            <a
              href={l.href}
              class="group bg-[var(--color-surface)] hover:bg-[var(--color-primary)] rounded-2xl p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl fade-up"
              style={`transition-delay: ${i * 80}ms`}
            >
              <div class="w-14 h-14 bg-[var(--color-primary)]/10 group-hover:bg-white/20 rounded-xl flex items-center justify-center mb-5 text-[var(--color-primary)] group-hover:text-white transition-colors">
                <Fragment set:html={l.icon} />
              </div>
              <h3 class="font-heading font-700 text-[var(--color-text)] group-hover:text-white text-lg mb-3 transition-colors">
                {l.titel}
              </h3>
              <p class="text-[var(--color-text-muted)] group-hover:text-white/80 text-sm leading-relaxed transition-colors">
                {l.text}
              </p>
              <div class="mt-4 flex items-center gap-1 text-[var(--color-primary-text)] group-hover:text-white text-sm font-semibold transition-colors">
                Mehr erfahren
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="14" height="14" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         §27 — GRÜNDER-STORY
    ═══════════════════════════════════════════════ -->
    <section id="ueber-uns" class="py-20 sm:py-28 bg-[var(--color-surface)]" aria-labelledby="ueber-uns-heading">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Bild -->
          <div class="fade-up relative">
            <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl">
              <img
                src="/images/ueber-uns.jpg"
                alt="Sebastian Martini — Inhaber Paul Martini Sanitär"
                class="w-full h-full object-cover"
                width="600"
                height="450"
                loading="lazy"
              />
            </div>
            <!-- Floating badge -->
            <div class="absolute -bottom-4 -right-4 bg-[var(--color-accent)] text-white rounded-xl px-5 py-3 shadow-lg shadow-orange-900/30">
              <div class="font-bold text-xl">3.</div>
              <div class="text-xs font-medium">Generation</div>
            </div>
          </div>

          <!-- Text -->
          <div class="fade-up">
            <span class="inline-block bg-[var(--color-primary)]/10 text-[var(--color-primary-text)] font-semibold text-sm px-4 py-1.5 rounded-full mb-5">Über uns</span>
            <h2 id="ueber-uns-heading" class="mb-5">
              Handwerk mit<br />
              <span class="text-[var(--color-primary-text)]">Herz &amp; Tradition</span>
            </h2>
            <p class="text-[var(--color-text-muted)] mb-4 leading-relaxed">
              Paul Martini Sanitär ist ein Familienbetrieb aus Kehrig bei Mayen — bereits in der dritten
              Generation. Inhaber Sebastian Martini steht persönlich für höchste Qualität, Pünktlichkeit
              und ehrliche Beratung.
            </p>
            <p class="text-[var(--color-text-muted)] mb-6 leading-relaxed">
              Ob neue Badezimmersanierung, moderne Wärmepumpe oder Klimaanlage — wir setzen Ihre Wünsche
              professionell um und kümmern uns um alles, damit Sie sich keine Sorgen machen müssen.
              Als Fachbetrieb bei Mayen sind wir in der Region bekannt und geschätzt.
            </p>

            <blockquote class="border-l-4 border-[var(--color-accent)] pl-5 py-2 mb-8">
              <p class="text-[var(--color-text)] font-medium italic text-lg leading-snug">
                „Wir behandeln jedes Zuhause wie unseres — mit dem Respekt,
                den Ihr Vertrauen verdient."
              </p>
              <cite class="text-[var(--color-text-muted)] text-sm mt-2 block not-italic">— Sebastian Martini, Inhaber</cite>
            </blockquote>

            <div class="grid grid-cols-3 gap-4">
              {[
                { zahl: '15+', label: 'Jahre Erfahrung' },
                { zahl: '5,0', label: 'Ø Google-Bewertung' },
                { zahl: '100%', label: 'Kundenzufriedenheit' },
              ].map(s => (
                <div class="text-center bg-white rounded-xl p-4 shadow-sm">
                  <div class="font-heading font-800 text-[var(--color-primary-text)] text-2xl">{s.zahl}</div>
                  <div class="text-[var(--color-text-muted)] text-xs mt-1">{s.label}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         §6 — PROZESS
    ═══════════════════════════════════════════════ -->
