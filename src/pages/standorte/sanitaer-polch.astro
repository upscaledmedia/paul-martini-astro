---
import BaseLayout from '../../components/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const tel = '02651-4019589';
const telHref = 'tel:+4926514019589';
---

<BaseLayout
  title="Sanitär & Heizung in Polch | Paul Martini"
  description="Ihr SHK-Fachbetrieb für Polch — Badezimmersanierung, Heizung, Wärmepumpe & Klimatechnik. Meisterbetrieb aus Kehrig, schnell vor Ort in Polch. ☎ 02651-4019589"
>
  <Header />

  <main class="pt-16 sm:pt-20">

    <!-- HERO -->
    <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden bg-[var(--color-secondary)]" aria-label="Hero">
      <div class="absolute inset-0" aria-hidden="true">
        <img src="/images/hero-bg.jpg" alt="" class="w-full h-full object-cover opacity-20" width="1920" height="1080" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-br from-[#0B1D35]/90 via-[#0D2B4A]/80 to-[#0A1628]/70"></div>
      </div>
      <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-[var(--color-primary)]/10 rounded-full blur-3xl" aria-hidden="true"></div>

      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center py-20">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 text-white/90 text-sm font-medium mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16" class="text-[var(--color-accent-light)]" aria-hidden="true">
            <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
          </svg>
          5,0 bei Google · Meisterbetrieb · Familienbetrieb seit 3 Generationen
        </div>

        <h1 class="text-white mb-6">
          Ihr Sanitär & Heizungsbauer<br />
          <span class="text-[var(--color-accent-light)]">in Polch</span>
        </h1>

        <p class="text-white/75 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
          Badezimmersanierung, Heizungsmodernisierung und Klimatechnik für Polch und Umgebung —
          schnell, zuverlässig und zum fairen Preis. <strong class="text-white">Wir kommen zu Ihnen.</strong>
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={telHref}
            class="inline-flex items-center justify-center gap-3 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold text-lg px-8 py-4 rounded-xl transition-all shadow-lg shadow-orange-900/30 hover:shadow-orange-900/50 hover:-translate-y-0.5"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="22" height="22" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
            </svg>
            {tel} anrufen
          </a>
          <a
            href="/kontakt/"
            class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white/60 text-white font-semibold text-lg px-8 py-4 rounded-xl transition-all hover:bg-white/10"
          >
            Anfrage stellen
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- VERTRAUENSLEISTE -->
    <section class="bg-[var(--color-primary)] py-6" aria-label="Vertrauenssignale">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-white text-center">
          <div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28" class="text-yellow-300 shrink-0" aria-hidden="true">
              <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
            </svg>
            <div class="text-left">
              <div class="font-bold text-lg leading-tight">5,0 Sterne</div>
              <div class="text-white/80 text-xs">15 Google-Bewertungen</div>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28" class="shrink-0" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
            </svg>
            <div class="text-left">
              <div class="font-bold text-lg leading-tight">Meisterbetrieb</div>
              <div class="text-white/80 text-xs">Zertifizierter Fachbetrieb</div>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28" class="shrink-0" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <div class="text-left">
              <div class="font-bold text-lg leading-tight">Polch & Umgebung</div>
              <div class="text-white/80 text-xs">Schnell vor Ort in Polch</div>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28" class="shrink-0" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
            </svg>
            <div class="text-left">
              <div class="font-bold text-lg leading-tight">3. Generation</div>
              <div class="text-white/80 text-xs">Familienbetrieb mit Tradition</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LEISTUNGEN IN POLCH -->
    <section class="py-20 sm:py-28 bg-white" aria-labelledby="leistungen-heading">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-14 fade-up">
          <span class="inline-block bg-[var(--color-primary)]/10 text-[var(--color-primary-text)] font-semibold text-sm px-4 py-1.5 rounded-full mb-4">Für Polch und Umgebung</span>
          <h2 id="leistungen-heading" class="mb-4">
            Ihr SHK-Fachbetrieb<br />
            <span class="text-[var(--color-primary-text)]">direkt in Ihrer Nähe</span>
          </h2>
          <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto text-lg">
            Als Meisterbetrieb aus Kehrig sind wir schnell in Polch vor Ort — für Badezimmersanierungen,
            Heizungsmodernisierungen und Klimaanlagen.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            {
              href: '/leistungen/badezimmersanierung/',
              titel: 'Badezimmersanierung',
              text: 'Komplette Badsanierungen in Polch — von der Planung bis zur Übergabe. Barrierefrei, modern und auf Wunsch energieeffizient.',
              icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" /></svg>`,
            },
            {
              href: '/leistungen/heizung/',
              titel: 'Heizung & Wärmepumpe',
              text: 'Moderne Heizsysteme und Wärmepumpen für Polch. Wir beantragen BAFA- und KfW-Förderung für Sie.',
              icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" /></svg>`,
            },
            {
              href: '/leistungen/klimatechnik/',
              titel: 'Klimatechnik',
              text: 'Energiesparende Klimaanlagen für Ihr Zuhause in Polch — kühlen im Sommer, heizen im Winter.',
              icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>`,
            },
            {
              href: '/leistungen/reparaturen/',
              titel: 'Reparaturen & Notdienst',
              text: 'Schnelle Hilfe bei Rohrbruch, Heizungsausfall oder Verstopfung — auch in Polch zuverlässig und fair.',
              icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" /></svg>`,
            },
          ].map((l, i) => (
            <a
              href={l.href}
              class="group bg-[var(--color-surface)] hover:bg-[var(--color-primary)] rounded-2xl p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl fade-up"
              style={`transition-delay: ${i * 80}ms`}
            >
              <div class="w-14 h-14 bg-[var(--color-primary)]/10 group-hover:bg-white/20 rounded-xl flex items-center justify-center mb-5 text-[var(--color-primary)] group-hover:text-white transition-colors">
                <Fragment set:html={l.icon} />
              </div>
              <h3 class="font-heading font-700 text-[var(--color-text)] group-hover:text-white text-lg mb-3 transition-colors">
                {l.titel}
              </h3>
              <p class="text-[var(--color-text-muted)] group-hover:text-white/80 text-sm leading-relaxed transition-colors">
                {l.text}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- WARUM WIR IN POLCH -->
    <section class="py-20 sm:py-28 bg-[var(--color-surface)]" aria-labelledby="warum-heading">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-14 fade-up">
          <h2 id="warum-heading" class="mb-4">
            Warum Polcher auf<br />
            <span class="text-[var(--color-primary-text)]">Paul Martini vertrauen</span>
          </h2>
        </div>

        <div class="grid sm:grid-cols-3 gap-8">
          {[
            {
              titel: 'Kurze Anfahrt',
              text: 'Von Kehrig nach Polch sind es nur wenige Minuten. Wir sind schnell bei Ihnen — auch im Notfall.',
              icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>`,
            },
            {
              titel: 'Meisterqualität',
              text: 'Als eingetragener Meisterbetrieb garantieren wir höchste Qualität und Sicherheit bei allen Arbeiten.',
              icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>`,
            },
            {
              titel: 'Faire Preise',
              text: 'Transparente Kostenvoranschläge ohne versteckte Gebühren. Sie wissen immer, was Sie erwartet.',
              icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" /></svg>`,
            },
          ].map(item => (
            <div class="bg-white rounded-2xl p-8 text-center shadow-sm fade-up">
              <div class="w-14 h-14 bg-[var(--color-primary)]/10 rounded-xl flex items-center justify-center mx-auto mb-5 text-[var(--color-primary)]">
                <Fragment set:html={item.icon} />
              </div>
              <h3 class="font-heading font-700 text-[var(--color-text)] text-lg mb-3">{item.titel}</h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-[var(--color-secondary)]" aria-labelledby="cta-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 id="cta-heading" class="text-white text-3xl sm:text-4xl font-heading font-800 mb-4">
          Jetzt Termin anfragen
        </h2>
        <p class="text-white/75 text-lg mb-10">
          Rufen Sie uns an oder schreiben Sie uns — wir melden uns innerhalb eines Werktages.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={telHref}
            class="inline-flex items-center justify-center gap-3 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-bold text-lg px-8 py-4 rounded-xl transition-all shadow-lg hover:-translate-y-0.5"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="22" height="22" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
            </svg>
            {tel} anrufen
          </a>
          <a
            href="/kontakt/"
            class="inline-flex items-center justify-center gap-2 border-2 border-white/40 hover:border-white text-white font-semibold text-lg px-8 py-4 rounded-xl transition-all hover:bg-white/10"
          >
            Anfrage stellen
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
