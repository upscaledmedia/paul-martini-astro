---
const tel = '02651-4019589';
const telHref = 'tel:+4926514019589';

const leistungen = [
  { label: 'Badezimmersanierung', href: '/leistungen/badezimmersanierung/' },
  { label: 'Heizung & Wärmepumpe', href: '/leistungen/heizung/' },
  { label: 'Klimatechnik', href: '/leistungen/klimatechnik/' },
  { label: 'Reparaturen & Notdienst', href: '/leistungen/reparaturen/' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-secondary)]/95 backdrop-blur-sm border-b border-white/10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16 sm:h-20">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 shrink-0" aria-label="Paul Martini Sanitär - zur Startseite">
      <img src="/images/logo.svg" alt="Paul Martini Sanitär Logo" class="h-10 sm:h-12 w-auto brightness-0 invert" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-7" aria-label="Hauptnavigation">

      <!-- Leistungen Dropdown -->
      <div class="relative group">
        <button
          type="button"
          class="flex items-center gap-1 text-white/80 hover:text-white text-sm font-medium transition-colors py-1"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Leistungen
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="12" height="12" class="transition-transform duration-200 group-hover:rotate-180" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </button>
        <!-- Dropdown -->
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 pointer-events-none group-hover:pointer-events-auto">
          <div class="bg-white rounded-xl shadow-2xl shadow-black/20 border border-gray-100 py-2 w-60">
            {leistungen.map(l => (
              <a
                href={l.href}
                class={`block px-5 py-3 text-sm font-medium transition-colors ${currentPath === l.href ? 'text-[var(--color-primary-text)] bg-[var(--color-surface)]' : 'text-[var(--color-text)] hover:text-[var(--color-primary-text)] hover:bg-[var(--color-surface)]'}`}
              >
                {l.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <a href="/ueber-uns/" class={`text-sm font-medium transition-colors ${currentPath === '/ueber-uns/' ? 'text-white' : 'text-white/80 hover:text-white'}`}>Über uns</a>
      <a href="/karriere/" class={`text-sm font-medium transition-colors ${currentPath === '/karriere/' ? 'text-white' : 'text-white/80 hover:text-white'}`}>Karriere</a>
      <a href="/kontakt/" class={`text-sm font-medium transition-colors ${currentPath === '/kontakt/' ? 'text-white' : 'text-white/80 hover:text-white'}`}>Kontakt</a>
    </nav>

    <!-- Desktop CTA -->
    <a
      href={telHref}
      class="hidden sm:flex items-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors shrink-0"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="16" height="16" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
      </svg>
      {tel}
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      type="button"
      class="md:hidden text-white p-2 -mr-2"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="24" height="24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="24" height="24" class="hidden">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-nav" class="hidden md:hidden bg-[var(--color-secondary)] border-t border-white/10">
    <nav class="px-4 py-4 flex flex-col gap-1" aria-label="Mobile Navigation">
      <!-- Leistungen expandable -->
      <button
        id="mobile-leistungen-btn"
        type="button"
        class="flex items-center justify-between w-full text-white/80 hover:text-white font-medium py-3 border-b border-white/10"
        aria-expanded="false"
      >
        Leistungen
        <svg id="mobile-leistungen-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="16" height="16" class="transition-transform">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
      </button>
      <div id="mobile-leistungen-list" class="hidden pl-4 pb-2 flex flex-col gap-1">
        {leistungen.map(l => (
          <a href={l.href} class="text-white/70 hover:text-white py-2 text-sm font-medium block">{l.label}</a>
        ))}
      </div>

      <a href="/ueber-uns/" class="text-white/80 hover:text-white font-medium py-3 border-b border-white/10 block">Über uns</a>
      <a href="/karriere/" class="text-white/80 hover:text-white font-medium py-3 border-b border-white/10 block">Karriere</a>
      <a href="/kontakt/" class="text-white/80 hover:text-white font-medium py-3 border-b border-white/10 block">Kontakt</a>
      <a href={telHref} class="mt-3 bg-[var(--color-accent)] hover:bg-[var(--color-accent-light)] text-white font-semibold px-4 py-3 rounded-lg text-center block transition-colors">
        {tel} anrufen
      </a>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !nav?.classList.contains('hidden');
    nav?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Mobile leistungen accordion
  const leistBtn = document.getElementById('mobile-leistungen-btn');
  const leistList = document.getElementById('mobile-leistungen-list');
  const leistIcon = document.getElementById('mobile-leistungen-icon');

  leistBtn?.addEventListener('click', () => {
    const isOpen = !leistList?.classList.contains('hidden');
    leistList?.classList.toggle('hidden');
    leistIcon?.classList.toggle('rotate-180', !isOpen);
    leistBtn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
