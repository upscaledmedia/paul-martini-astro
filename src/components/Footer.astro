---
const tel = '02651-4019589';
const telHref = 'tel:+4926514019589';
const email = 'basti.martini@web.de';
const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-secondary)] text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 sm:py-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Spalte 1: Firma -->
      <div class="lg:col-span-2">
        <a href="/" class="flex flex-col leading-tight mb-5" aria-label="Paul Martini Sanitär - zur Startseite">
          <span class="font-heading font-800 text-white text-xl tracking-tight">Paul Martini</span>
          <span class="text-[var(--color-accent-light)] text-sm font-medium tracking-widest uppercase">Sanitär · Heizung · Klima</span>
        </a>
        <p class="text-white/60 text-sm leading-relaxed mb-6 max-w-xs">
          Ihr SHK-Fachbetrieb in Kehrig bei Mayen — Familienbetrieb seit 3 Generationen. Badezimmersanierung, Heizung, Wärmepumpe & Klimatechnik.
        </p>
        <div class="flex flex-col gap-2">
          <a href={telHref} class="flex items-center gap-2 text-white/80 hover:text-white text-sm transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="16" height="16" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
            </svg>
            {tel}
          </a>
          <a href={`mailto:${email}`} class="flex items-center gap-2 text-white/80 hover:text-white text-sm transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="16" height="16" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            {email}
          </a>
          <span class="flex items-center gap-2 text-white/60 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="16" height="16" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            Polcher Straße 31, 56729 Kehrig
          </span>
        </div>
      </div>

      <!-- Spalte 2: Leistungen -->
      <div>
        <h3 class="text-white font-heading font-700 text-base mb-4">Leistungen</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/leistungen/badezimmersanierung/" class="text-white/60 hover:text-white text-sm transition-colors">Badezimmersanierung</a></li>
          <li><a href="/leistungen/heizung/" class="text-white/60 hover:text-white text-sm transition-colors">Heizung & Wärmepumpe</a></li>
          <li><a href="/leistungen/klimatechnik/" class="text-white/60 hover:text-white text-sm transition-colors">Klimatechnik</a></li>
          <li><a href="/leistungen/reparaturen/" class="text-white/60 hover:text-white text-sm transition-colors">Reparaturen & Notdienst</a></li>
        </ul>
      </div>

      <!-- Spalte 3: Links -->
      <div>
        <h3 class="text-white font-heading font-700 text-base mb-4">Unternehmen</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/ueber-uns/" class="text-white/60 hover:text-white text-sm transition-colors">Über uns</a></li>
          <li><a href="/karriere/" class="text-white/60 hover:text-white text-sm transition-colors">Karriere</a></li>
          <li><a href="/kontakt/" class="text-white/60 hover:text-white text-sm transition-colors">Kontakt</a></li>
          <li><a href="/impressum/" class="text-white/60 hover:text-white text-sm transition-colors">Impressum</a></li>
          <li><a href="/datenschutz/" class="text-white/60 hover:text-white text-sm transition-colors">Datenschutz</a></li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-white/40 text-xs">
      <p>© {year} Paul Martini Sanitär · Heizung · Klima — Alle Rechte vorbehalten</p>
      <p>Meisterbetrieb · Region Mayen</p>
    </div>
  </div>
</footer>
